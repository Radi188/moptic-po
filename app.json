{
  "expo": {
    "name": "M Optic-PO",
    "slug": "moptic",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/logo-staff.png",
    "scheme": "moptic",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.moptic.staff",
      "buildNumber": "2",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.moptic.staff",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#A8867B",
        "foregroundImage": "./assets/images/logo-staff.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo-staff.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-staff.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#A8867B"
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4c4ede3a-dcdd-4872-bfdc-3f7095b81857"
      }
    },
    "owner": "neji"
  }
}
